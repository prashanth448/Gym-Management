PORT=5000
JWT_SECRET=replace-with-a-long-random-secret
OTP_SECRET=replace-with-another-secret-for-otp-hashing
ADMIN_SETUP_KEY=replace-with-a-one-time-admin-bootstrap-key

# Preferred hosted or production MongoDB connection string.
MONGO_URI=

# Local MongoDB fallback visible in Robo 3T.
LOCAL_MONGO_URI=mongodb://127.0.0.1:27017/fitLedger

# Allowed frontend origins for REST and real-time connections.
# Example: https://app.example.com,https://admin.example.com
CLIENT_ORIGIN=

# Trust proxy setting when running behind Nginx/Load Balancer.
TRUST_PROXY=1

# General API rate limiting.
API_RATE_LIMIT_WINDOW_MINUTES=15
API_RATE_LIMIT_MAX_REQUESTS=300

# Stricter auth and OTP rate limiting.
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX_ATTEMPTS=8

# Email OTP delivery via Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# SMS OTP delivery via Twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
